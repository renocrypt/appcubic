---
import Footer from "../components/Footer.astro";
import Nav from "../components/Nav.astro";
import ServiceCard from "../components/ServiceCard.astro";
import { services, site } from "../data/site";
import BaseLayout from "../layouts/BaseLayout.astro";
import { ChartNoAxesCombined, ShieldCheck, Workflow } from "@lucide/astro";
---

<BaseLayout title={site.title} description={site.description} pathname="/">
  <Nav />
  <main>
    <section class="hero" aria-labelledby="hero-title">
      <div class="hero-content">
        <p class="eyebrow">Applied AI systems, venture incubation, and research workflows</p>
        <h1 id="hero-title">AppCubic</h1>
        <p class="hero-copy">
          AppCubic builds applied AI systems and venture prototypes at the boundary of research,
          operations, and market deployment.
        </p>
        <div class="hero-actions">
          <a class="button primary" href="/about/">Explore the studio</a>
          <a class="button secondary" href={site.links.research}>Research systems</a>
        </div>
      </div>
    </section>

    <section class="section" aria-labelledby="services-title">
      <div class="section-shell">
        <div class="section-header">
          <p class="section-label">Focus areas</p>
          <h2 id="services-title">Applied AI with an operator's bias.</h2>
          <p>
            The studio work sits where prototypes have to become usable: agent workflows, technical
            products, scientific tooling, and the operating systems around them.
          </p>
        </div>
        <div class="service-grid">
          {services.map((service) => <ServiceCard {...service} />)}
        </div>
      </div>
    </section>

    <section class="section alt" aria-labelledby="principles-title">
      <div class="section-shell">
        <div class="section-header centered">
          <p class="section-label">Operating principles</p>
          <h2 id="principles-title">Engineered for technical partners.</h2>
          <p>
            AppCubic is a dedicated AI engineering studio. We build, test, and move applied
            agentic systems toward production alongside teams who deeply understand their problem
            domain.
          </p>
        </div>
        <div class="proof-grid">
          <article class="principle">
            <div class="principle-kicker">
              <span class="principle-icon">
                <ShieldCheck size={20} stroke-width={1.8} />
              </span>
            </div>
            <h3>Predictable Intelligence</h3>
            <p>
              Agentic systems require evaluation frameworks, retrieval discipline, and explicit
              tool boundaries. We engineer for reliable behavior, not magic.
            </p>
          </article>
          <article class="principle">
            <div class="principle-kicker">
              <span class="principle-icon">
                <Workflow size={20} stroke-width={1.8} />
              </span>
            </div>
            <h3>Production-Grade Workflows</h3>
            <p>
              We prioritize robust, end-to-end systems shaped by real operating constraints over
              isolated, fragile prompt experiments.
            </p>
          </article>
          <article class="principle">
            <div class="principle-kicker">
              <span class="principle-icon">
                <ChartNoAxesCombined size={20} stroke-width={1.8} />
              </span>
            </div>
            <h3>Compounding Execution</h3>
            <p>
              Technical depth accelerates market learning. Data infrastructure, scientific rigor,
              and product judgment reinforce one another.
            </p>
          </article>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>
